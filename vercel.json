{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": "src/data/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!assets/|static/|favicon.ico|.*\\..*).*)$",
      "destination": "/index.html"
    }
  ]
}
